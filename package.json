    "canvas-confetti": "^1.9.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "jsbarcode": "^3.12.3",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supabase": "^2.83.0",
    "unpdf": "^1.6.2",
    "vite": "^5.4.2",

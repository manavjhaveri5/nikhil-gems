    "electron:build": "electron-builder --config electron-builder.yml",
    "electron:release": "electron-builder --config electron-builder.yml --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.99.1",

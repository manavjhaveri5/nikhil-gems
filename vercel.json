{
  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    },
    "api/etsy.js": {
      "maxDuration": 60
    },
    "api/raj.js": {
      "maxDuration": 60
    },
    "api/shopify.js": {
      "maxDuration": 90
    },
    "api/canva.js": {
      "maxDuration": 120
    },
    "api/telegram.js": {
      "maxDuration": 60
    },
    "api/openai.js": {
      "maxDuration": 30
    },
    "api/notify-cron.js": {
      "maxDuration": 20
    },
    "api/version.js": {
      "maxDuration": 5
    }
  },
  "crons": [
    {
      "path": "/api/notify-cron",
      "schedule": "30 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}

{
  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    },
    "api/etsy.js": {
      "maxDuration": 60
    },
    "api/shopify.js": {
      "maxDuration": 90
    },
    "api/canva.js": {
      "maxDuration": 120
    },
    "api/openai.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
